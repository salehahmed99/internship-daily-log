# Copy this file to .env (in your working directory) and fill in your values.
# Never commit the real .env file — it contains a secret credential.

# Notion internal integration secret, from https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The 32-character ID of the target database, taken from its URL:
# https://www.notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Optional) 32-character ID of the scratchpad page you overwrite daily with
# your raw, messy notes. If set, you can ask to "pull my notes from Notion"
# and skip pasting them in by hand. The integration must be connected to this
# page too (Page -> ••• -> Connections -> Add connection). A full page URL
# also works here — the script extracts the ID either way.
NOTION_SCRATCHPAD_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
